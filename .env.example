# ============================================
# 必填：拷貝此檔為 .env.local 並填入實際值
# ============================================

# --- SerpApi ---
# 從 https://serpapi.com/manage-api-key 取得
SERPAPI_KEY=

# --- Supabase ---
# 從你的 Supabase 專案 → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LINE Messaging API ---
# 從 LINE Developers Console → Channel → Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# 每日推播的目標：
# - 若是個人/測試：填你的 LINE userId（U 開頭）
# - 若是群組：填群組 groupId（C 開頭）
# - 留空則用 broadcast（推給所有加好友的使用者，需 verified bot）
LINE_DAILY_PUSH_TARGET=

# --- Cron 安全驗證 ---
# 隨便產一個長字串（>32 字元），Vercel Cron 呼叫時會帶這個 token
CRON_SECRET=

# --- 航班搜尋預設 ---
# 出發地 IATA 代碼（桃園 = TPE）
DEFAULT_ORIGIN=TPE
# 目的地 IATA 代碼（東京羽田 = HND；成田 = NRT）
DEFAULT_DESTINATION=HND
# 旅遊長度（天）—— 排程會自動找未來 N 天範圍內的便宜票
DEFAULT_TRIP_DAYS_AHEAD_MIN=14
DEFAULT_TRIP_DAYS_AHEAD_MAX=90
# 旅遊天數
DEFAULT_TRIP_LENGTH_DAYS=4

# --- 應用程式網址（部署後填上 Vercel 給的網址）---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- LIFF（LINE 內嵌網頁，給 /liff/search 使用）---
# 在 LINE Developers Console → Channel → LIFF → Add 取得
NEXT_PUBLIC_LIFF_ID=

# --- Admin 後台密碼（隨便設一組）---
ADMIN_PASSWORD=

# --- LINE Bot ID（顯示 QR code 用，預設讀取）---
LINE_BASIC_ID=

# --- Sentry（可選，錯誤監控）---
# 在 https://sentry.io 開免費帳號，建專案後拿 DSN
NEXT_PUBLIC_SENTRY_DSN=
